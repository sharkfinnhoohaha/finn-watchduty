# Synoptic Data API token — Watch Duty's actual weather-vane provider.
#
# With this set, /api/wind queries Synoptic's stations/latest over the region
# bbox across ALL networks (RAWS · CWOP/personal · mesonet · airport) — i.e. the
# full network Watch Duty draws. Without it, the app falls back to the keyless
# NWS feed (ridge RAWS + mesonets only; see app/data/region.ts).
#
# Get a free token from Synoptic's Open Access program:
#   https://synopticdata.com/open-access-program/
#
# Local dev:  copy this file to .env.local and fill in the token (.env.local is
#             gitignored, so the secret never lands in the repo).
# Production: set SYNOPTIC_TOKEN in your Vercel project
#             (Settings → Environment Variables) and redeploy.
#
# Verify a token quickly:  SYNOPTIC_TOKEN=… node scripts/check-synoptic.mjs
SYNOPTIC_TOKEN=

# ---------------------------------------------------------------------------
# Wind analysis pipeline knobs (all optional; documented defaults in
# app/lib/pipeline/config.ts). Set any of these in the deploy env to retune
# without a rebuild. Values shown are the defaults.
# ---------------------------------------------------------------------------
# Background source: rtma | hrrr | openmeteo (rtma/hrrr are stubbed, fall back
# to openmeteo).
# WIND_BACKGROUND_SOURCE=openmeteo
# Rendered layer: sustained | gust.
# WIND_AVERAGING_TARGET=sustained
# Analysis window and time decay, minutes.
# WIND_WINDOW_MIN=120
# WIND_DECAY_MIN=45
# Horizontal and vertical decorrelation lengths.
# WIND_DECORR_KM=18
# WIND_DECORR_VERT_M=400
# Inversion base elevation used by the air-mass rule, metres (HRRR profile seam).
# WIND_INVERSION_BASE_M=500
# Buddy-check radius (km) and rejection tolerance (km/h).
# WIND_QC_BUDDY_KM=25
# WIND_QC_BUDDY_TOL_KMH=25
